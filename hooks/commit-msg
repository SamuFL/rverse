#!/usr/bin/env bash
# commit-msg hook — Enforce GitHub issue/PR reference in every commit message.
#
# Exempt commits:
#   - Merge commits (auto-generated by git)
#   - Revert commits
#   - Version tag commits

set -euo pipefail

COMMIT_MSG_FILE="$1"
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# Allow merge commits
if echo "$COMMIT_MSG" | grep -qE "^Merge (branch|remote-tracking|tag)"; then
    exit 0
fi

# Allow revert commits
if echo "$COMMIT_MSG" | grep -qE "^Revert "; then
    exit 0
fi

# Allow version tag commits
if echo "$COMMIT_MSG" | grep -qE "^(v[0-9]|Release |Tag )"; then
    exit 0
fi

# Require a GitHub issue or PR reference somewhere in the message
if echo "$COMMIT_MSG" | grep -qE "#[0-9]+"; then
    exit 0
fi

echo ""
echo "❌ commit-msg hook: No GitHub issue or PR reference found in commit message."
echo ""
echo "   Every normal commit must reference the related GitHub issue or PR. Examples:"
echo "     git commit -m \"Archive legacy tracker docs and hooks (#26)\""
echo "     git commit -m \"Fix sample loading handoff after drag-and-drop merge (#28)\""
echo ""
echo "   Exempt: merge commits, reverts, version tags."
echo "   To bypass (emergencies only): git commit --no-verify"
echo ""
exit 1
