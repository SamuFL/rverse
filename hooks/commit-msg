#!/usr/bin/env bash
# commit-msg hook — Enforce Beads issue ID in every commit message.
#
# Valid patterns:
#   (bd-xxxx)        — e.g. (bd-a1b2)
#   (bd-rverse-xxx)  — e.g. (bd-rverse-n84)
#   (rverse-xxx)     — e.g. (rverse-n84)
#
# Exempt commits:
#   - Merge commits (auto-generated by git)
#   - Beads sync commits (auto-generated by bd sync)
#   - Revert commits
#   - Version tag commits

set -euo pipefail

COMMIT_MSG_FILE="$1"
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# Allow merge commits
if echo "$COMMIT_MSG" | grep -qE "^Merge (branch|remote-tracking|tag)"; then
    exit 0
fi

# Allow beads sync commits
if echo "$COMMIT_MSG" | grep -qiE "^(Sync beads|Beads:)"; then
    exit 0
fi

# Allow revert commits
if echo "$COMMIT_MSG" | grep -qE "^Revert "; then
    exit 0
fi

# Allow version tag commits
if echo "$COMMIT_MSG" | grep -qE "^(v[0-9]|Release |Tag )"; then
    exit 0
fi

# Require a beads ID somewhere in the message
# Matches: (bd-xxxx), (rverse-xxxx), bd-rverse-xxxx, rverse-xxxx
if echo "$COMMIT_MSG" | grep -qE "(bd-[a-z0-9]+|rverse-[a-z0-9]+)"; then
    exit 0
fi

echo ""
echo "❌ commit-msg hook: No Beads issue ID found in commit message."
echo ""
echo "   Every commit must reference a Beads issue. Examples:"
echo "     git commit -m \"Add stutter gate (bd-rverse-n84)\""
echo "     git commit -m \"Fix buffer overflow (rverse-n84)\""
echo ""
echo "   Exempt: merge commits, beads sync, reverts, version tags."
echo "   To bypass (emergencies only): git commit --no-verify"
echo ""
exit 1
