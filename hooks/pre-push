#!/usr/bin/env bash
# pre-push hook — Enforce git-flow branching rules.
#
# Rules:
#   1. Never push directly to 'main' — use release/ or hotfix/ branches
#   2. Warn (but allow) pushes to 'develop' — prefer feature/ branches

set -euo pipefail

REMOTE="$1"
CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "unknown")

# --- Rule 1: Block direct pushes to main ---
if [ "$CURRENT_BRANCH" = "main" ]; then
    echo ""
    echo "❌ pre-push hook: Direct push to 'main' is not allowed."
    echo ""
    echo "   This project uses git-flow. To get code into main:"
    echo "     1. Merge your feature branch into 'develop'"
    echo "     2. Create a release/ branch from 'develop'"
    echo "     3. Merge the release/ branch into 'main'"
    echo ""
    echo "   For emergencies: create a hotfix/ branch from 'main'."
    echo "   To bypass (emergencies only): git push --no-verify"
    echo ""
    exit 1
fi

# --- Rule 2: Warn on direct push to develop ---
if [ "$CURRENT_BRANCH" = "develop" ]; then
    echo ""
    echo "⚠️  Pushing directly to 'develop'. Prefer feature branches:"
    echo "   git checkout -b feature/<issue-number>-description"
    echo ""
fi

exit 0
